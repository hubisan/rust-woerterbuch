                                          :examples
                                          ("das Haus war bis auf den letzten Platz gefüllt"
                                           "unser Haus ist ausverkauft")
                                          :definitions nil)
                                     (:id 2 :dwds-id "d-1-1-2-2" :label "β)"
                                          :definition "Hotel" :qualifiers nil
                                          :examples
