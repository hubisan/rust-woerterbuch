(:input "Bank" :lemma "Bank" :sources ((:source openthesaurus :lemma "Bank" :ok t :url "https://www.openthesaurus.de/synonyme/Bank" :homographs ((:id 1 :lemma "Bank" :definitions ((:id 1 :lemma "Bank" :categories nil :synonyms ("Parkbank" "Sitzbank")) (:id 2 :lemma "Bank" :categories ("Ökonomie") :synonyms ("Bankhaus" "Finanzinstitut" "Finanzinstitution" "Geldhaus" "Geldinstitut" "Geschäftsbank" "Kreditanstalt" "Kreditinstitut" "Sparkasse")))))) (:source dwds :lemma "Bank" :ok t :url "https://www.dwds.de/wb/Bank" :homographs ((:id 1 :hidx "1" :lemma "Bank" :title "Bank, die" :wortart "Substantiv" :grammar "Substantiv (Femininum) · Genitiv Singular: Bank · Nominativ Plural: Bänke" :origin "1 Bank f. ‘Sitzmöbel für mehrere’, ahd. (9. Jh.), mhd. mnl. banc, asächs. mnd. nl. bank, aengl. benc, engl. bench, anord. bekkr, schwed. bänk führen auf germ. *bankiz. Die Etymologie ist nicht sicher. Vergleicht man anord. bakki (-kk- aus -nk-) ‘Erhöhung, Hügel, Flußufer’ und die zu germ. *baka(n)- ‘Rücken’ (s. Bache sowie Backbord, 2 Backe) gehörige Wortgruppe (ohne inlautenden Nasal), so läßt sich über die Vorstellung ‘Rundes, Gewölbtes’ für germ. *bankiz ‘gebogene, gerundete Erdaufschüttung zum Sitzen’, später ‘gerundeter, aus Holz gemachter Sitz’ (z. B. auf dem Thingplatz) annehmen. Aber auch Verbindung zu aind. bhanákti ‘biegt, bricht’, bhaṅgáḥ ‘Biegung, Bruch’ und Anschluß an die Wurzel ie. *bheg-, *bheng- ‘schlagen, brechen’ ist denkbar; *bankiz wäre dann ursprünglich die zum Sitzen flach geschlagene, geebnete Erde. S. auch 2 Bank. In bildlichen Wendungen: auf die lange Bank schieben ‘verzögern’, anfänglich Gerichtsakten in die langen Truhen (den Aufbewahrungsort) bringen (15. Jh.); durch die Bank ‘allesamt’ (wie sie nebeneinander sitzen)." :idioms ("durch die Bank" "etw. auf die lange Bank schieben") :definitions ((:id 1 :dwds-id "d-1-1" :label "1." :definition "Sitz für mehrere Personen nebeneinander, meist aus Holz" :qualifiers nil :examples ("eine Bank im Park, vor dem Haus" "Anlagen mit Bänken" "die Bänke im Zirkus, in den Schulen, Hörsälen" "eine Bank ohne, mit Lehne" "die vordere, hintere, oberste, unterste, zweite, dritte Bank" "er saß in der Schule in der, auf der letzten, ersten Bank (= war der schlechteste, beste Schüler)" "eine roh gezimmerte, grün gestrichene, einfache, harte, gepolsterte, geschnitzte, steinerne, schattige Bank" "ein Bänkchen herbeiholen" "die ganze Bank einnehmen" "die Bank wegrücken, zur Seite rücken" "sich auf einer Bank niederlassen, auf eine Bank setzen" "sich lang auf eine Bank strecken" "auf einer Bank reiten" "der Schüler trat aus der Bank (heraus)" "etw. unter die Bank schieben, stecken, unter der Bank hervorziehen" "unter die Bank kriechen" "jmdn. unter die Bank trinken (= so lange mit ihm zechen, bis er betrunken daliegt)" "vor leeren Bänken spielen, sprechen (= wenig Zuschauer, Zuhörer haben)" "etw. auf die lange Bank schieben (= etw. aufschieben)" "(alle) durch die Bank (= alle)" "Denn Bank an Bank gedränget sitzen / … Der Griechen Völker wartend da" "Auf dieser Bank von Stein will ich mich setzen") :definitions ((:id 1 :dwds-id "d-1-1-1" :label "●" :definition "ohne Ausnahme" :qualifiers nil :examples ("auf den Schwindel sind alle durch die Bank hereingefallen" "ihr habt es (alle) durch die Bank missverstanden" "alle Versuche waren durch die Bank fehlgeschlagen") :definitions nil))) (:id 2 :dwds-id "d-1-2" :label "2." :definition "Handwerkstisch" :qualifiers nil :examples ("Walter setzte den Stahl an … alles Weitere schaffte die Bank (= Drehbank) allein") :definitions nil) (:id 3 :dwds-id "d-1-3" :label "3." :definition "Zusammenballung, Anhäufung" :qualifiers nil :examples nil :definitions ((:id 1 :dwds-id "d-1-3-1" :label "a)" :definition "von Sand, Fels, Schlamm, Tieren in Gewässern" :qualifiers nil :examples ("das Boot war auf eine Bank gefahren, gelaufen" "er konnte nicht von der Bank loskommen") :definitions nil) (:id 2 :dwds-id "d-1-3-2" :label "b)" :definition "von Gestein, Kohle in der Erde" :qualifiers nil :examples nil :definitions nil) (:id 3 :dwds-id "d-1-3-3" :label "c)" :definition "von Wolken, Dunst am Himmel" :qualifiers nil :examples ("Die Schwaden weißlichen Dunstes … verschwammen in der Abenddämmerung zu gelblichen und rötlichen Bänken") :definitions nil))))) (:id 2 :hidx "2" :lemma "Bank" :title "Bank, die" :wortart "Substantiv" :grammar "Substantiv (Femininum) · Genitiv Singular: Bank · Nominativ Plural: Banken" :origin "2 Bank f. ‘Geschäft für Geldverkehr’, in seiner Herkunft identisch mit 1 Bank (s. d.), das früh in die roman. Sprachen eindringt. Ital. banco m. (Nebenform banca f.), anfangs (wie mhd. wehselbanc) der Tisch der Geldwechsler, wird im 15. Jh. rückentlehnt, wobei die ital. Lautung Bancho, Ban(c)ko lange beibehalten wird. Nach frz. banque f. begegnen im 18. Jh. Pluralformen wie Banques, Banquen, unter deren Einfluß bei Anlehnung an 1 Bank sich die heutige Form und das feminine Genus durchsetzen. Auf frz. Vorbild beruht auch die Verwendung von Bank als ‘Spielbank’ im Glücksspiel. – Banknote f. Die Prägung engl. banknote (17. Jh.) wird im 18. Jh. ins Dt. übernommen, ältere Bezeichnungen wie Bankbillet, Bankzettel ablösend." :idioms ("eine Bank sein" "sichere Bank" "todsichere Bank") :definitions ((:id 1 :dwds-id "d-2-1" :label "1." :definition "Unternehmen, das gewerbsmäßig Geldgeschäfte und Börsengeschäfte betreibt" :qualifiers nil :examples ("Früher folgte der Weltspartag einem festen Ritual. Am letzten Arbeitstag im Oktober gingen die Kinder zusammen mit ihren Eltern in die örtliche Bank oder Sparkasse, ein prall gefülltes Sparschwein im Gepäck. Als Belohnung stieg nicht nur der Betrag auf dem Sparkonto, oft legten die Geldhäuser noch ein kleines Geschenk obendrauf." "[…] wie schon in den Vorjahren beklagten sich auch 2019 Millionen Sparer über die Nullzinsen auf Tages‑ und Festgeld bei ihrer Bank." "Schuld an diesem Preisniveau sei eine Verlagerung des Börsengeschäfts auf Rohstoffzertifikate: Spekulanten, Banken und Fonds glaubten, auf den Rohstoffmärkten deutlich höhere Gewinne erzielen zu können als mit anderen Investments." "Immer mehr Banken verschieben ihren wichtigsten Standort in Asien oder ihre Basis für das Derivate‑ und Devisengeschäft zur Zeit von Tokio nach Singapur." "Wir beginnen in diesen Tagen mit der Freigabe des Geschäftsdarlehens der Banken und Sparkassen, insbesondere mit der Eröffnung der Kassenstellen, um dadurch der Wirtschaft im allgemeinen wieder das notwendige Blut zuzuführen.") :definitions ((:id 1 :dwds-id "d-2-1-1" :label "●" :definition "einzelne Filiale einer ²Bank" :qualifiers ("metonymisch") :examples ("Es gibt nicht genug Beweise, dass Sie die Bank ausgeraubt haben." "Früher war in dem Gebäude mal eine Bank." "Ein Beispiel: In einer Bank warten Kunden geduldig vor dem Schalter. Die Regeln sind hier klar definiert, es gibt eine Schlange, einer nach dem anderen kommt an die Reihe." "Betritt man diese Bank, laufen einem Schauer der Ehrfurcht den Rücke herunter – kostbare Marmorböden, hohe, schmale Fenster wie im Grand Central Terminal, erhabene Deckenbögen.") :definitions nil))) (:id 2 :dwds-id "d-2-2" :label "2." :definition "Einrichtung, in der etwas in großer Menge gesammelt, aufbewahrt, verwaltet wird und entnommen werden kann" :qualifiers nil :examples ("Es ist das größte Überlebens‑Projekt seit der Arche Noah: Die internationale Bank für Pflanzensamen auf Spitzbergen. Gestern wurde sie eröffnet. Im Permafrostboden der norwegischen Insel sollen bis zu 4,5 Millionen Samenproben von Weizen, Mais, Bohnen & Co. eingelagert werden." "Den Forschern stand […] eine riesige Bank an Blutproben […] zur Verfügung, gewonnen im Labor, das die Universität München und die GTZ (= Deutsche Gesellschaft für Technische Zusammenarbeit) gerade am größten Krankenhaus der Region aufbauten […]. Hier wurden zum ersten Mal in der Region freiwillige HIV‑Tests und Beratungen für die Bevölkerung angeboten." "Ich behaupte, dass am Ende Verhütungsmittel total unnötig sein werden. Die Menschen werden ihre Spermien und Eier in einer Bank auf Eis legen können und lassen sich anschließend sterilisieren." "Ein Verfahren, Spermien‑Vorläuferzellen einzufrieren und später in Hoden heranreifen zu lassen, haben kürzlich amerikanische Forscher entwickelt. Diese Technik könnte es ermöglichen, Tiere als lebende Banken für Spermien verschiedener Arten, auch für solche des Menschen, zu nutzen." "Bei der Polnischen Medizinischen Akademie in Warschau ist jetzt die erste, zentrale Gewebebank der Volksrepublik Polen eingerichtet worden. Die Bank verfügt über konservierte Fragmente von Knochen, Sehnen, Gelenk‑ und Knorpelgeweben, die für Transplantationen vor allem in der Orthopädie verwendet werden.") :definitions nil) (:id 3 :dwds-id "d-2-3" :label "3." :definition "" :qualifiers ("Glücksspiel") :examples nil :definitions ((:id 1 :dwds-id "d-2-3-1" :label "a)" :definition "Geldeinsatz desjenigen Spielers, der bei Bankhalter-Spielen allein gegen alle übrigen spielt" :qualifiers nil :examples ("die Bank übernehmen, halten, sprengen" "Bei Spielen wie Poker und Baccarat fungiert das Kasino – anders als im Black Jack und Roulette – nicht als Bank und macht deshalb keinen Gewinn." "Die Kugel kommt auf der schwarzen Acht zum Liegen. Ein Mann […] starrt auf das Türmchen seiner 100‑Dollar‑Chips, das der Croupier zur Bank hinüberschiebt." "Wie ein Spieler, der seine gerade eingestrichenen Gewinne auf eine Karte setzt, um die Bank zu sprengen, scheint auch Arafat immer wieder bereit, alles zu riskieren – nur um dann letztlich doch zu verlieren." "Ein Croupier, im Fachjargon Dealer, hält die Bank, ihm sitzen bis zu sieben aktive Spieler gegenüber." "Einer [der Spieler] übernimmt die Bank, und die meisten spielen […] auf seiner Seite […]. Die anderen spielen gegen ihn […]. […] die Partei, die »die Bank hält«, […] investiert [Geld], um jedem der […] Spieler […] eine Chance zu geben, sich mit kleinen Beträgen entweder für die Bank oder gegen die Bank zu engagieren.") :definitions nil) (:id 2 :dwds-id "d-2-3-2" :label "b)" :definition "Synonym zu Bankhalter = Person, die das Spiel leitet, die Einsätze verwaltet und gegen die die übrigen Spieler spielen" :qualifiers ("metonymisch") :examples ("Nebenberuflich war die 25‑Jährige bisher im Automatenkasino in Baden als Gästebetreuerin tätig. Der Beruf des Croupiers sei anspruchsvoller, sagt sie; immerhin verwalte sie als » Bank « Jetons im Wert von 15.000 Franken." "Die Regeln [beim Black Jack] sind simpel: Jeder spielt für sich, und alle spielen gegen die Bank.") :definitions nil) (:id 3 :dwds-id "d-2-3-3" :label "c)" :definition "eine Bank sein (MWA) = etw. sein, das die an es gestellten (hohen) Erwartungen verlässlich erfüllt; jmd. sein, der die von ihm erwartete (erfolgreiche) Leistung mit Sicherheit erbringt" :qualifiers ("umgangssprachlich") :examples nil :definitions nil))))))) (:source duden :lemma "Bank" :ok t :url ("https://www.duden.de/rechtschreibung/Bank_Sitzgelegenheit?amp" "https://www.duden.de/rechtschreibung/Bank_Geldinstitut?amp") :homographs ((:id 1 :lemma "Bank" :title "Bank, die" :wortart "Substantiv" :grammar "Substantiv, feminin" :origin "mittelhochdeutsch, althochdeutsch banc = Bank, Tisch, ursprünglich = Erhöhung" :idioms nil :synonyms nil :url "https://www.duden.de/rechtschreibung/Bank_Sitzgelegenheit?amp" :definitions ((:id 1 :duden-id nil :label "1" :definition nil :qualifiers nil :examples nil :idioms nil :image nil :definitions ((:id 1 :duden-id "Bedeutung-1a" :label "1a" :definition "Sitzgelegenheit aus Holz, Stein o. Ä., die mehreren Personen nebeneinander Platz bietet" :qualifiers nil :examples ("sich auf eine Bank setzen" "in der Schule in einer Bank (Schulbank) sitzen" "der Angeklagte saß unruhig in der Bank (Anklagebank)") :idioms ("etwas auf die lange Bank schieben (umgangssprachlich: etwas Unangenehmes aufschieben, hinauszögern: er schob den Arztbesuch auf die lange Bank; eigentlich = bis zur Bearbeitung in den langen Aktentruhen der Gerichte aufbewahren lassen)" "durch die Bank (umgangssprachlich: durchweg, ohne Ausnahme, ohne Unterschied: das Obst war durch die Bank frisch; eigentlich = in der Reihenfolge, wie die Leute auf einer Bank sitzen)" "vor leeren Bänken (vor wenigen Zuhörenden, Zuschauenden: sie spielten vor leeren Bänken)") :image "https://cdn.duden.de/_media_/full/B/Bank-201100043436.jpg" :definitions nil) (:id 2 :duden-id "Bedeutung-1b" :label "1b" :definition "Auswechselbank" :qualifiers ("Gebrauch: Sport") :examples nil :idioms nil :image "https://cdn.duden.de/_media_/full/B/Bank-201100287392.jpg" :definitions nil))) (:id 2 :duden-id nil :label "2" :definition nil :qualifiers nil :examples nil :idioms nil :image nil :definitions ((:id 1 :duden-id "Bedeutung-2a" :label "2a" :definition "Kurzform für: verschiedene Handwerkstische wie Drehbank, Hobelbank, Werkbank u. a." :qualifiers nil :examples ("an der Bank arbeiten") :idioms nil :image nil :definitions nil) (:id 2 :duden-id "Bedeutung-2b" :label "2b" :definition "bankförmiges Turngerät" :qualifiers nil :examples nil :idioms nil :image nil :definitions nil))) (:id 3 :duden-id nil :label "3" :definition nil :qualifiers nil :examples nil :idioms nil :image nil :definitions ((:id 1 :duden-id "Bedeutung-3a" :label "3a" :definition "Kurzform für: Sandbank" :qualifiers nil :examples nil :idioms nil :image nil :definitions nil) (:id 2 :duden-id "Bedeutung-3b" :label "3b" :definition "Anhäufung von Meereslebewesen, die eine Erhöhung über dem Meeresgrund hervorruft" :qualifiers nil :examples ("hohe Bänke von Austern, Korallen") :idioms nil :image nil :definitions nil) (:id 3 :duden-id "Bedeutung-3c" :label "3c" :definition "lange Wolken- oder Dunstschicht" :qualifiers nil :examples nil :idioms nil :image nil :definitions nil) (:id 4 :duden-id "Bedeutung-3d" :label "3d" :definition "vom umliegenden Gestein gesonderte, fest zusammenhängende Gesteinsschicht" :qualifiers ("Gebrauch: Geologie") :examples nil :idioms nil :image nil :definitions nil))) (:id 4 :duden-id "Bedeutung-4" :label "4" :definition "unverändert beibehaltene Vorhersage auf Tippscheinen" :qualifiers nil :examples ("eine Bank tippen" "dieses Spiel ist eine Bank (kann man als Bank tippen)" "⟨in übertragener Bedeutung:⟩ diese Stürmerin ist eine Bank in unserem Team (umgangssprachlich; man kann sich hundertprozentig auf sie verlassen); dieses Geschenk ist eine Bank (ein sicherer Erfolg)") :idioms nil :image nil :definitions nil) (:id 5 :duden-id "Bedeutung-5" :label "5" :definition "Ausgangsstellung auf dem Boden mit auf Knie und Arme gestütztem Körper" :qualifiers ("Gebrauch: Sport") :examples nil :idioms nil :image nil :definitions nil))) (:id 2 :lemma "Bank" :title "Bank, die" :wortart "Substantiv" :grammar "Substantiv, feminin" :origin "italienisch banco, banca, eigentlich = Tisch des Geldwechslers, aus dem Germanischen" :idioms nil :synonyms ("Bankhaus" "Geldinstitut" "Kreditanstalt" "Kreditinstitut") :url "https://www.duden.de/rechtschreibung/Bank_Geldinstitut?amp" :definitions ((:id 1 :duden-id nil :label "1" :definition nil :qualifiers nil :examples nil :idioms nil :image nil :definitions ((:id 1 :duden-id "Bedeutung-1a" :label "1a" :definition "Unternehmen, das Geld- und Kreditgeschäfte betreibt und den Zahlungsverkehr vermittelt" :qualifiers nil :examples ("ein Konto bei der Bank haben" "Geld auf der Bank [liegen] haben, von der Bank holen") :idioms nil :image nil :definitions nil) (:id 2 :duden-id "Bedeutung-1b" :label "1b" :definition "Gebäude, in dem eine Bank (1a) untergebracht ist" :qualifiers nil :examples ("die Bank ist 1910 gebaut worden") :idioms nil :image "https://cdn.duden.de/_media_/full/B/Bank-201100287376.jpg" :definitions nil))) (:id 2 :duden-id "Bedeutung-2" :label "2" :definition "Geldeinsatz eines einzelnen Bankhalters, der gegen alle anderen Spieler spielt oder den Einsatz verwaltet" :qualifiers ("Gebrauch: Glücksspiel") :examples ("die Bank halten, sprengen" "gegen die Bank spielen") :idioms nil :image nil :definitions nil))))) (:source wiktionary :lemma "Bank" :ok t :url "https://de.wiktionary.org/wiki/Bank" :homographs ((:id 1 :lemma "Bank" :title "Bank, Substantiv, f, Bänke" :wortart "Substantiv" :grammar "Substantiv" :origin "mittelhochdeutsch banc, althochdeutsch bank, germanisch *banki- „Bank“, belegt seit dem 9. Jahrhundert" :idioms ("vor leeren Bänken sprechen" "etwas auf die lange Bank schieben" "durch die Bank") :synonyms ((:sense "2" :items ("Lage")) (:sense "5" :items ("Theke" "Tresen")) (:sense "6" :items ("Auswechselbank" "Ersatzbank"))) :url "https://de.wiktionary.org/wiki/Bank" :definitions ((:id 1 :label "1" :definition "Sitz- oder Ablagegelegenheit für mehrere Personen oder Dinge nebeneinander" :qualifiers nil :examples ("Sollen wir uns auf diese Bank setzen?" "„Nach dem Abendessen gingen Sung und Hideo auf eine Runde in den Park und saßen dann lange schweigend auf einer Bank am Teich.“" "„Smoaks setzte sich auf die gegenüberliegende Bank und sah ihn an.“" "„Die kleine Bank mit den zwei Kissen war fortgeräumt, und statt ihrer stand eine Chaiselongue da, darauf die Kranke ruhte, den Oberkörper mit einem Schal, die Füße mit einer Reisedecke zugedeckt, in die das Wappen der St. Arnauds oder vielleicht auch das der Woronesch von Zacha eingestickt war.“" "„Darüber wurde der Fußboden eingezogen, und an den Wänden stellte man Bänke auf, die gleichzeitig als Truhen dienten.“") :definitions nil) (:id 2 :label "2" :definition "geologische Formation" :qualifiers nil :examples ("„Eine Bank oder die Lage (lat. stratum, engl. bed, layer, abgekürzt Bk. oder Lg.) ist im Sprachgebrauch der Geologie, Geotechnik und Stratigraphie eine vom umliegenden Gestein deutlich in Struktur, Farbe oder Material gesonderte, zusammenhängende Gesteinsschicht.“" "Diese kalkhaltige Bank wurde von Steinsuchern in den letzten Jahrzehnten weitgehend abgebaut.") :definitions nil) (:id 3 :label "3" :definition "Ablagerung von Material in einem Gewässer" :qualifiers nil :examples ("In dieser Flussschlinge hat die Strömung eine schöne Bank gebildet.") :definitions nil) (:id 4 :label "4" :definition "Anhäufung biologischer Rückstände auf dem Meeresgrund" :qualifiers nil :examples ("Eine besondere Art von Bank ist das Korallenriff.") :definitions nil) (:id 5 :label "5" :definition "Verkaufstisch oder Ladentisch für Käse, Fleisch, Fisch, Salat oder Ähnliches" :qualifiers nil :examples ("Vor der Bank des Konsumvereins waren Frauen, Kinder und Männer zu sehen.") :definitions nil) (:id 6 :label "6" :definition "Sport, kurz für: Auswechselbank, Ersatzbank" :qualifiers nil :examples ("„Der Nationalspieler hatte sein Zwicken im Muskel aus der Vorwoche zwar auskuriert, er blieb aber wie so oft zunächst auf der Bank. “" "„Die vorgenommenen Wechsel (durchschnittlich 4,23 pro Spiel) zeigten oft Wirkung: Sieben Scorerpunkte - vier Tore und drei Assists - kamen bei den Hamburgern bislang von der Bank. “") :definitions nil))) (:id 2 :lemma "Bank" :title "Bank, Substantiv, f, Banken" :wortart "Substantiv" :grammar "Substantiv" :origin "im 13. Jahrhundert von italienisch banco, banca „ Tisch “ für „ Geldhandelsort, Vorratsplatz “ entlehnt. Dem italienischen Wort liegt althochdeutsch banc / bank zu Grunde." :idioms ("Die Bank gewinnt immer." "ich bin doch nicht die Bank von England!" "eine sichere Bank") :synonyms ((:sense "1" :items ("Geldhaus" "Geldinstitut" "Finanzinstitut" "Finanzunternehmen" "Kreditinstitut" "Bankhaus")) (:sense "2" :items ("Kasino" "Spielbank"))) :url "https://de.wiktionary.org/wiki/Bank" :definitions ((:id 1 :label "1" :definition "Finanzwesen: Geldinstitut für Finanzdienstleistungen" :qualifiers nil :examples ("Diese Bank wäre bei dem Großbrand gestern fast abgebrannt." "„Die Guthaben bei Banken und Sparkassen seien gesichert und blieben unberührt.“") :definitions nil) (:id 2 :label "2" :definition "Glücksspiellokal; auch eine der Spielparteien kann als Bank bezeichnet werden (beim Roulette gewinnt die Bank, wenn keine der gesetzten Kombinationen fällt), oder auch ein zentraler Vorrat, der selbst nicht am Wettstreit teilnimmt, kann so bezeichnet werden (beispielsweise der Vorrat an Straßen, Häusern und Hotels, die beim Monopoly bisher noch von keinem Mitspieler gekauft wurden)" :qualifiers nil :examples ("Keiner hat richtig gesetzt, die Einsätze gehen an die Bank." "„Ein sehr ehrenwerter Patrizier hatte mich mit einem Viertel an seiner Bank beteiligt und übergab mir in den ersten Tagen der Fastenzeit eine ziemlich bedeutende Summe.“") :definitions nil)))))))
